<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatClient"
        mc:Ignorable="d"
        Title="Лавров болталка" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="7*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Content="Введите IP адрес" VerticalAlignment="Bottom"/>
            <TextBox Grid.Row="1" Margin="10 15"/>
            <Label Grid.Row="2" Content="Введите порт" VerticalAlignment="Bottom"/>
            <TextBox Grid.Row="3" Margin="10 15"/>
            <Label Grid.Row="4" Content="Введите имя" VerticalAlignment="Bottom"/>
            <TextBox Grid.Row="5" Margin="10 15"/>
            <Button Grid.Row="6" Content="Подключиться" Margin="10 10"/>
        </Grid>
    </Grid>
</Window>
