<Window x:Class="Lab12WPF.View.AutoOwnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab12WPF.View"
        mc:Ignorable="d"
        Title="AutoOwnerWindow" Height="550" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <GroupBox Header="Автовладелец" Padding="5" Grid.Row="0" Margin="10">
                <StackPanel>
                    <Label>ФИО</Label>
                    <TextBox Text="{Binding FIO}" Margin="10 5"/>
                    <Label>Телефон</Label>
                    <TextBox Text="{Binding Phone}" Margin="10 5"/>
                    <Label>Марка</Label>
                    <TextBox Text="{Binding Marka}" Margin="10 5"/>
                    <Label>Номер</Label>
                    <TextBox Text="{Binding Number}" Margin="10 5"/>
                    <Label>Технический паспорт</Label>
                    <TextBox Text="{Binding TechPassport}" Margin="10 5"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Адрес" Padding="5" Grid.Row="1" Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBox Text="{Binding PostalCode}" Grid.Row="0" Grid.Column="0"
                             Margin="10 15"/>
                    <TextBox Text="{Binding Country}" Grid.Row="1" Grid.Column="0"
                        Margin="10 15"/>
                    <TextBox Text="{Binding Region}" Grid.Row="2" Grid.Column="0"
                        Margin="10 15"/>
                    <TextBox Text="{Binding Area}" Grid.Row="3" Grid.Column="0"
                        Margin="10 15"/>
                    <TextBox Text="{Binding City}" Grid.Row="0" Grid.Column="1"
                        Margin="10 15"/>
                    <TextBox Text="{Binding Street}" Grid.Row="1" Grid.Column="1"
                        Margin="10 15"/>
                    <TextBox Text="{Binding Home}" Grid.Row="2" Grid.Column="1"
                        Margin="10 15"/>
                    <TextBox Text="{Binding Department}" Grid.Row="3" Grid.Column="1"
                        Margin="10 15"/>
                </Grid>
            </GroupBox>
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.9*"/>
                <RowDefinition Height="0.1*"/>
            </Grid.RowDefinitions>
            <Image Grid.Row="0" Margin="10" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Content="Загрузить" Grid.Column="0" Margin="20 10"/>
                <Button Content="Очистить" Grid.Column="1" Margin="20 10"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
