<Window x:Class="WPFLesson2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFLesson2"
        mc:Ignorable="d"
        Title="Второе окно" Height="800" Width="1000" Icon="/Images/logo.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Image Source="/Images/logo.jpg" Grid.Column="0"/>
            <TextBlock Text="Рога и копыта" Grid.Column="1" Style="{StaticResource Header}"/>
            <Image Source="/Images/User.jpg" Grid.Column="2"/>
        </Grid>
        <TextBlock Text="Форма записи на посящение мероприятия"
                   Grid.Row="1" Style="{StaticResource Header}"
                   HorizontalAlignment="Center"/>
        <Grid Grid.Row="2">
            
        </Grid>
    </Grid>
</Window>
